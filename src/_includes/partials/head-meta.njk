<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{% if title %}{{ title }} — {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
<meta name="description" content="{{ description or site.tagline }}">

<!-- Open Graph -->
<meta property="og:type" content="{{ ogType or 'website' }}">
<meta property="og:site_name" content="{{ site.title }}">
<meta property="og:title" content="{% if title %}{{ title }} — {{ site.title }}{% else %}{{ site.title }}{% endif %}">
<meta property="og:description" content="{{ description or site.tagline }}">
<meta property="og:url" content="{{ site.url }}{{ page.url }}">
<meta property="og:image" content="{{ ogImage or (site.url + '/assets/media/Landing%20at%20Juffureh.jpg') }}">
<meta property="og:image:alt" content="{{ ogImageAlt or 'Documentary photography by Leon Morgan' }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="800">

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{% if title %}{{ title }} — {{ site.title }}{% else %}{{ site.title }}{% endif %}">
<meta name="twitter:description" content="{{ description or site.tagline }}">
<meta name="twitter:image" content="{{ ogImage or (site.url + '/assets/media/Landing%20at%20Juffureh.jpg') }}">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bowlby+One&family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=Inter:wght@400;500;600;800&display=swap">

<link rel="stylesheet" href="/assets/css/site.css">
<link rel="icon" href="/favicon.ico">
